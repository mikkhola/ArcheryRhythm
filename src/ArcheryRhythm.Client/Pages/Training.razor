@page "/"
@using ArcheryRhythm.Core
@using Microsoft.Extensions.Localization
@implements IDisposable
@inject RunEngine Engine
@inject SettingsStore Store
@inject IStringLocalizer<SharedResources> T

<PageTitle>@T["Training_Title"]</PageTitle>

@if (_loading)
{
    <p>@T["Loading"]</p>
}
else
{
    <div class="training-root">
        @if (!string.IsNullOrWhiteSpace(Engine.State.NonBlockingBannerKey))
        {
            <div class="alert alert-warning" role="alert">
                @T[Engine.State.NonBlockingBannerKey!]
            </div>
        }

        <div class="d-flex justify-content-between align-items-baseline flex-wrap gap-2">
            <h1 class="m-0">@T["Training_Title"]</h1>
            <a class="btn btn-outline-secondary" href="settings">@T["Nav_Settings"]</a>
        </div>

        <div class="card mt-3">
            <div class="card-body">
                <div class="training-grid">
                    <div>
                        <div class="text-muted">@T["Training_Arrow"]</div>
                        <div class="display-6 fw-semibold">@Engine.State.ArrowIndex / @Engine.State.ArrowCount</div>
                    </div>
                    <div>
                        <div class="text-muted">@T["Training_Stage"]</div>
                        <div class="display-6 fw-semibold">@StageLabel(Engine.State.Stage)</div>
                    </div>
                </div>

                <div class="countdown mt-3">
                    @CountdownText()
                </div>

                <div class="progress mt-2" style="height: 14px;">
                    <div class="progress-bar" role="progressbar" style="width: @ProgressWidth()"></div>
                </div>

                @if (Engine.State.NextStage is not null)
                {
                    <div class="mt-3 text-muted">
                        @T["Training_Next"]: <span class="fw-semibold">@StageLabel(Engine.State.NextStage.Value)</span>
                        (@(Engine.State.NextStageDurationSeconds?.ToString("0") ?? "0") s)
                    </div>
                }

                <div class="training-controls mt-4">
                    @if (!Engine.State.IsRunning)
                    {
                        <button class="btn btn-primary btn-lg" @onclick="StartAsync">@T["Training_Start"]</button>
                    }
                    else if (!Engine.State.IsPaused)
                    {
                        <button class="btn btn-warning btn-lg" @onclick="Pause">@T["Training_Pause"]</button>
                    }
                    else
                    {
                        <button class="btn btn-success btn-lg" @onclick="Resume">@T["Training_Resume"]</button>
                    }

                    <button class="btn btn-outline-danger btn-lg" @onclick="StopAsync" disabled="@(!Engine.State.IsRunning)">@T["Training_Stop"]</button>
                </div>

                @if (!Engine.State.IsRunning)
                {
                    <div class="mt-4">
                        <div class="text-muted">@T["Training_CurrentSettings"]</div>
                        <div class="small">
                            @T["Stage_Prepare"]: @_settings.PrepareSeconds s,
                            @T["Stage_Draw"]: @_settings.DrawSeconds s,
                            @T["Stage_Aim"]: @_settings.AimSeconds s,
                            @T["Settings_ArrowsPerEnd"]: @_settings.ArrowsPerEnd
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private SequenceSettings _settings = new();

    protected override async Task OnInitializedAsync()
    {
        Engine.StateChanged += OnEngineStateChanged;
        _settings = await Store.LoadSettingsAsync();
        _loading = false;
    }

    private void OnEngineStateChanged()
        => _ = InvokeAsync(StateHasChanged);

    private async Task StartAsync()
    {
        _settings = await Store.LoadSettingsAsync();
        await Engine.StartAsync(_settings);
    }

    private void Pause() => Engine.Pause();
    private void Resume() => Engine.Resume();
    private Task StopAsync() => Engine.StopAsync();

    private string StageLabel(StageType stage) => stage switch
    {
        StageType.Prepare => T["Stage_Prepare"],
        StageType.Draw => T["Stage_Draw"],
        StageType.Aim => T["Stage_Aim"],
        _ => stage.ToString(),
    };

    private string CountdownText()
    {
        var remaining = (int)Math.Ceiling(Engine.State.StageRemainingSeconds);
        return remaining < 0 ? "0" : remaining.ToString();
    }

    private string ProgressWidth()
        => FormattableString.Invariant($"{Engine.State.StageProgress01 * 100:0.##}%");

    public void Dispose()
    {
        Engine.StateChanged -= OnEngineStateChanged;
    }
}
